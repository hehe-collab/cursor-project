const path = require('path');
const fs = require('fs');

const useJson = process.env.DB_TYPE === 'json' || !process.env.DB_PASSWORD;

let pool;
let initDatabase;
let getEpisodesList;

if (useJson) {
  // JSON 文件存储：无需 MySQL，开箱即用
  const dataDir = path.join(__dirname, '../../data');
  const dataFile = path.join(dataDir, 'db.json');
  fs.mkdirSync(dataDir, { recursive: true });

  let data = { admins: [], categories: [], tags: [], dramas: [], drama_episodes: [], drama_tags: [], users: [], settings: [] };
  if (fs.existsSync(dataFile)) {
    try {
      data = JSON.parse(fs.readFileSync(dataFile, 'utf8'));
    } catch {}
  }

  const save = () => fs.writeFileSync(dataFile, JSON.stringify(data, null, 0));

  const toMysqlResult = (rows, insertId) => {
    const r = Array.isArray(rows) ? rows : [rows];
    return [r, []];
  };

  pool = {
    query: async (sql, params = []) => {
      const upper = sql.toUpperCase().trim();
      if (upper.startsWith('SELECT')) {
        if (sql.includes('COUNT(*)') && sql.includes('admins')) {
          return toMysqlResult([{ count: data.admins.length }]);
        }
        if (sql.includes('COUNT(*)') && sql.includes('categories')) {
          return toMysqlResult([{ count: data.categories.length }]);
        }
        if (sql.includes('COUNT(*)') && sql.includes('FROM dramas') && !sql.includes('dramas d')) {
          return toMysqlResult([{ count: data.dramas.length }]);
        }
        if (sql.includes('COUNT(*)') && sql.includes('users')) {
          let list = data.users;
          if (!sql.includes('WHERE')) {
            return toMysqlResult([{ count: list.length }]);
          }
          if (sql.includes('WHERE')) {
            const kw = params.find(p => typeof p === 'string' && p.includes('%'));
            if (kw) list = list.filter(u => (u.username || '').toLowerCase().includes((kw.replace(/%/g, '')).toLowerCase()));
            const pidIdx = params.findIndex(p => typeof p === 'string' && !p.includes('%') && p.length > 0);
            if (pidIdx >= 0 && params[pidIdx]) list = list.filter(u => (u.promote_id || '').includes(params[pidIdx]));
          }
          return toMysqlResult([{ total: list.length }]);
        }
        if (sql.includes('COALESCE(SUM(view_count)') || sql.includes('SUM(view_count)')) {
          return toMysqlResult([{ total: data.dramas.reduce((s, d) => s + (d.view_count || 0), 0) }]);
        }
        if (sql.includes('CURDATE()') && sql.includes('dramas')) {
          const today = new Date().toISOString().slice(0, 10);
          return toMysqlResult([{ count: data.dramas.filter(d => (d.created_at || '').startsWith(today)).length }]);
        }
        if (sql.includes('admins')) {
          if (sql.includes('WHERE id') || sql.includes('id = ?')) {
            const u = data.admins.find(a => a.id == params[0]);
            return toMysqlResult(u ? [{ id: u.id, username: u.username, nickname: u.nickname, role: u.role }] : []);
          }
          if (sql.includes('WHERE username') || sql.includes('username = ?')) {
            const u = data.admins.find(a => a.username === params[0]);
            return toMysqlResult(u ? [u] : []);
          }
        }
        if (sql.includes('categories') && !sql.includes('dramas')) {
          const list = [...data.categories].sort((a, b) => (a.sort || 0) - (b.sort || 0));
          return toMysqlResult(list);
        }
        if (sql.includes('tags')) {
          if (sql.includes('drama_tags')) {
            const list = (data.drama_tags || []).filter(dt => dt.drama_id === parseInt(params[0])).map(dt => ({ tag_id: dt.tag_id }));
            return toMysqlResult(list);
          }
          return toMysqlResult([...data.tags]);
        }
        if (sql.includes('dramas') && sql.includes('drama_episodes')) {
          const list = (data.drama_episodes || []).filter(e => e.drama_id === parseInt(params[0])).sort((a, b) => a.episode_num - b.episode_num);
          return toMysqlResult(list);
        }
        if (sql.includes('settings')) {
          const list = (data.settings || []).map(s => ({ key_name: s.key_name, value: s.value }));
          return toMysqlResult(list);
        }
        if (sql.includes('users') && sql.includes('FROM users')) {
          let list = [...data.users].sort((a, b) => (b.id || 0) - (a.id || 0));
          if (sql.includes('WHERE')) {
            const kw = params.find(p => typeof p === 'string' && p.includes('%'));
            if (kw) list = list.filter(u => (u.username || '').toLowerCase().includes((kw.replace(/%/g, '')).toLowerCase()));
            const pidIdx = params.findIndex(p => typeof p === 'string' && !p.includes('%') && p.length > 0);
            if (pidIdx >= 0 && params[pidIdx]) list = list.filter(u => (u.promote_id || '').includes(params[pidIdx]));
          }
          const pageSize = params[params.length - 2] || 10;
          const offset = params[params.length - 1] || 0;
          return toMysqlResult(list.slice(offset, offset + pageSize));
        }
        if (sql.includes('dramas') && sql.includes('LEFT JOIN')) {
          const kw = params.find(p => typeof p === 'string' && p.includes('%'));
          const keyword = kw ? kw.replace(/%/g, '') : '';
          const catId = params.find(p => typeof p === 'number' || (typeof p === 'string' && !p.includes('%')));
          const status = params.find(p => ['draft', 'published', 'offline'].includes(p));
          let list = data.dramas.map(d => ({
            ...d,
            category_name: data.categories.find(c => c.id === d.category_id)?.name || '',
          }));
          if (keyword) list = list.filter(d => (d.title || '').includes(keyword));
          if (catId) list = list.filter(d => d.category_id === catId);
          if (status) list = list.filter(d => d.status === status);
          list.sort((a, b) => (b.sort || 0) - (a.sort || 0) || (b.id || 0) - (a.id || 0));
          const total = list.length;
          const pageSize = params[params.length - 2] || 10;
          const offset = params[params.length - 1] || 0;
          list = list.slice(offset, offset + pageSize);
          return toMysqlResult(list);
        }
        if (sql.includes('COUNT(*)') && sql.includes('dramas d')) {
          const kw = params.find(p => typeof p === 'string' && p.includes('%'));
          const keyword = kw ? kw.replace(/%/g, '') : '';
          let list = data.dramas;
          if (keyword) list = list.filter(d => (d.title || '').includes(keyword));
          if (params[1]) list = list.filter(d => d.category_id === params[1]);
          if (params[2]) list = list.filter(d => d.status === params[2]);
          return toMysqlResult([{ total: list.length }]);
        }
        if (sql.includes('dramas d') && sql.includes('c.name')) {
          const id = params[params.length - 1] || params[0];
          const d = data.dramas.find(x => x.id === parseInt(id));
          if (!d) return toMysqlResult([]);
          const row = { ...d, category_name: data.categories.find(c => c.id === d.category_id)?.name || '' };
          return toMysqlResult([row]);
        }
      }
      if (upper.startsWith('INSERT')) {
        const table = sql.match(/INTO\s+(\w+)/i)?.[1];
        const id = Math.max(0, ...(data[table] || []).map(x => x.id || 0)) + 1;
        if (table === 'admins') {
          data.admins.push({ id, username: params[0], password: params[1], nickname: params[2], role: params[3], created_at: new Date().toISOString() });
        } else if (table === 'categories') {
          data.categories.push({ id, name: params[0], sort: params[1] || 0, created_at: new Date().toISOString() });
        } else if (table === 'tags') {
          data.tags.push({ id, name: params[0], created_at: new Date().toISOString() });
        } else if (table === 'dramas') {
          data.dramas.push({ id, title: params[0], cover: params[1] || '', description: params[2] || '', category_id: params[3] || null, status: params[4] || 'draft', view_count: 0, sort: params[5] || 0, created_at: new Date().toISOString(), updated_at: new Date().toISOString() });
        } else if (table === 'drama_tags') {
          (data.drama_tags = data.drama_tags || []).push({ drama_id: params[0], tag_id: params[1] });
        } else if (table === 'drama_episodes') {
          const epId = Math.max(0, ...(data.drama_episodes || []).map(e => e.id || 0)) + 1;
          (data.drama_episodes = data.drama_episodes || []).push({ id: epId, drama_id: params[0], episode_num: params[1], title: params[2] || '', video_id: params[3] || '', video_url: params[4] || '', duration: params[5] || 0, created_at: new Date().toISOString() });
        } else if (table === 'settings') {
          const existing = (data.settings = data.settings || []).findIndex(s => s.key_name === params[0]);
          const row = { key_name: params[0], value: String(params[1] || params[2] || ''), updated_at: new Date().toISOString() };
          if (existing >= 0) data.settings[existing] = row;
          else data.settings.push(row);
        }
        save();
        return toMysqlResult({ insertId: id, affectedRows: 1 });
      }
      if (upper.startsWith('UPDATE')) {
        const table = sql.match(/UPDATE\s+(\w+)/i)?.[1];
        if (table === 'dramas') {
          const d = data.dramas.find(x => x.id === parseInt(params[params.length - 1]));
          if (d) Object.assign(d, { title: params[0], cover: params[1], description: params[2], category_id: params[3], status: params[4], sort: params[5], updated_at: new Date().toISOString() });
        } else if (table === 'categories') {
          const c = data.categories.find(x => x.id === parseInt(params[2]));
          if (c) Object.assign(c, { name: params[0], sort: params[1] });
        } else if (table === 'tags') {
          const t = data.tags.find(x => x.id === parseInt(params[1]));
          if (t) t.name = params[0];
        } else if (table === 'settings') {
          const s = (data.settings || []).find(x => x.key_name === params[0]);
          if (s) s.value = String(params[1] || params[2] || '');
        } else if (table === 'drama_episodes') {
          const ep = (data.drama_episodes || []).find(e => e.id === parseInt(params[params.length - 1]));
          if (ep) ep.video_id = String(params[0] || '');
        }
        save();
        return toMysqlResult({ affectedRows: 1 });
      }
      if (upper.startsWith('DELETE')) {
        const table = sql.match(/FROM\s+(\w+)/i)?.[1];
        const id = parseInt(params[0]);
        if (table === 'dramas') {
          data.dramas = data.dramas.filter(x => x.id !== id);
          data.drama_episodes = (data.drama_episodes || []).filter(e => e.drama_id !== id);
          data.drama_tags = (data.drama_tags || []).filter(dt => dt.drama_id !== id);
        } else if (table === 'drama_tags') {
          data.drama_tags = (data.drama_tags || []).filter(dt => dt.drama_id !== id);
        } else if (table === 'drama_episodes') {
          data.drama_episodes = (data.drama_episodes || []).filter(e => e.drama_id !== id);
        } else if (table === 'categories') {
          data.categories = data.categories.filter(x => x.id !== id);
        } else if (table === 'tags') {
          data.tags = data.tags.filter(x => x.id !== id);
        }
        save();
        return toMysqlResult({ affectedRows: 1 });
      }
      return toMysqlResult([]);
    },
    getConnection: () => ({ query: pool.query, release: () => {} }),
  };

  initDatabase = async () => {
    const bcrypt = require('bcryptjs');
    if (!data.admins.length) {
      const hashedPassword = await bcrypt.hash('admin123', 10);
      data.admins.push({ id: 1, username: 'admin', password: hashedPassword, nickname: '超级管理员', role: 'super_admin', created_at: new Date().toISOString() });
      save();
      console.log('✅ 默认管理员已创建: admin / admin123');
    }
    if (!data.categories.length) {
      data.categories = [{ id: 1, name: '短剧', sort: 1, created_at: new Date().toISOString() }, { id: 2, name: '电影', sort: 2, created_at: new Date().toISOString() }, { id: 3, name: '电视剧', sort: 3, created_at: new Date().toISOString() }];
      save();
      console.log('✅ 默认分类已创建');
    }
    if (!data.tags.length) {
      data.tags = [{ id: 1, name: '甜宠', created_at: new Date().toISOString() }, { id: 2, name: '虐恋', created_at: new Date().toISOString() }, { id: 3, name: '都市', created_at: new Date().toISOString() }, { id: 4, name: '古装', created_at: new Date().toISOString() }];
      save();
      console.log('✅ 默认标签已创建');
    }
    if (!(data.dramas || []).length) {
      const now = new Date().toISOString();
      data.dramas = [
        { id: 1, title: '闪婚成宠', cover: 'https://picsum.photos/200/280?random=1', description: '一场意外让两人闪婚，从陌生到相爱的甜蜜故事', category_id: 1, status: 'published', view_count: 12580, sort: 10, created_at: now, updated_at: now },
        { id: 2, title: '霸道总裁的替身新娘', cover: 'https://picsum.photos/200/280?random=2', description: '替身新娘逆袭成为真爱的故事', category_id: 1, status: 'published', view_count: 8932, sort: 9, created_at: now, updated_at: now },
        { id: 3, title: '重生之豪门千金', cover: 'https://picsum.photos/200/280?random=3', description: '重生归来，改写命运', category_id: 1, status: 'published', view_count: 15620, sort: 8, created_at: now, updated_at: now },
      ];
      data.drama_episodes = [
        { id: 1, drama_id: 1, episode_num: 1, title: '第1集', video_id: '', video_url: '', duration: 0, created_at: now },
        { id: 2, drama_id: 1, episode_num: 2, title: '第2集', video_id: '', video_url: '', duration: 0, created_at: now },
        { id: 3, drama_id: 2, episode_num: 1, title: '第1集', video_id: '', video_url: '', duration: 0, created_at: now },
      ];
      data.drama_tags = [{ drama_id: 1, tag_id: 1 }, { drama_id: 1, tag_id: 3 }, { drama_id: 2, tag_id: 1 }, { drama_id: 2, tag_id: 2 }, { drama_id: 3, tag_id: 2 }];
      data.users = [
        { id: 1, username: '用户001', phone: '138****0001', avatar: '', status: 1, coin_balance: 100, promote_id: 'P001', promote_name: '推广A', created_at: now },
        { id: 2, username: '用户002', phone: '139****0002', avatar: '', status: 1, coin_balance: 50, promote_id: 'P002', promote_name: '推广B', created_at: now },
      ];
      save();
      console.log('✅ 演示数据已创建（3 部剧集、2 个用户）');
    }
    save();
    console.log('✅ 数据库初始化完成 (JSON 文件模式)');
  };

  getEpisodesList = (filter = {}) => {
    const dramas = data.dramas || [];
    const eps = data.drama_episodes || [];
    let list = [];
    for (const d of dramas) {
      const dEps = eps.filter(e => e.drama_id === d.id).sort((a, b) => (a.episode_num || 0) - (b.episode_num || 0));
      for (const ep of dEps) {
        list.push({
          id: ep.id || `${d.id}-${ep.episode_num}`,
          drama_id: d.id,
          title: d.title,
          episode_num: ep.episode_num,
          external_id: ep.video_id || '',
          created_at: ep.created_at || d.created_at,
        });
      }
      if (dEps.length === 0) list.push({ id: d.id, drama_id: d.id, title: d.title, episode_num: '-', external_id: '', created_at: d.created_at });
    }
    if (filter.dramaId) list = list.filter(x => String(x.drama_id) === String(filter.dramaId));
    if (filter.episodeNum) list = list.filter(x => String(x.episode_num) === String(filter.episodeNum));
    if (filter.externalId) list = list.filter(x => (x.external_id || '').includes(filter.externalId));
    const total = list.length;
    const page = parseInt(filter.page, 10) || 1;
    const pageSize = parseInt(filter.pageSize, 10) || 10;
    const offset = (page - 1) * pageSize;
    list = list.slice(offset, offset + pageSize);
    return { list, total };
  };
} else {
  const mysql = require('mysql2/promise');
  const dbName = process.env.DB_NAME || 'future_admin';
  pool = mysql.createPool({
    host: process.env.DB_HOST || 'localhost',
    port: process.env.DB_PORT || 3306,
    user: process.env.DB_USER || 'root',
    password: process.env.DB_PASSWORD || '',
    database: dbName,
    waitForConnections: true,
    connectionLimit: 10,
    queueLimit: 0,
  });

  initDatabase = async () => {
    const tempConn = await mysql.createConnection({
      host: process.env.DB_HOST || 'localhost',
      port: process.env.DB_PORT || 3306,
      user: process.env.DB_USER || 'root',
      password: process.env.DB_PASSWORD || '',
    });
    await tempConn.query(`CREATE DATABASE IF NOT EXISTS \`${dbName}\` DEFAULT CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci`);
    await tempConn.end();

    const connection = await pool.getConnection();
    try {
      await connection.query(`CREATE TABLE IF NOT EXISTS admins (id INT AUTO_INCREMENT PRIMARY KEY, username VARCHAR(50) UNIQUE NOT NULL, password VARCHAR(255) NOT NULL, nickname VARCHAR(50), role VARCHAR(20) DEFAULT 'admin', created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)`);
      await connection.query(`CREATE TABLE IF NOT EXISTS categories (id INT AUTO_INCREMENT PRIMARY KEY, name VARCHAR(50) NOT NULL, sort INT DEFAULT 0, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)`);
      await connection.query(`CREATE TABLE IF NOT EXISTS tags (id INT AUTO_INCREMENT PRIMARY KEY, name VARCHAR(50) NOT NULL, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)`);
      await connection.query(`CREATE TABLE IF NOT EXISTS dramas (id INT AUTO_INCREMENT PRIMARY KEY, title VARCHAR(200) NOT NULL, cover VARCHAR(500), description TEXT, category_id INT, status ENUM('draft','published','offline') DEFAULT 'draft', view_count INT DEFAULT 0, sort INT DEFAULT 0, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP, updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP, FOREIGN KEY (category_id) REFERENCES categories(id) ON DELETE SET NULL)`);
      await connection.query(`CREATE TABLE IF NOT EXISTS drama_episodes (id INT AUTO_INCREMENT PRIMARY KEY, drama_id INT NOT NULL, episode_num INT NOT NULL, title VARCHAR(200), video_id VARCHAR(100), video_url VARCHAR(500), duration INT DEFAULT 0, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP, FOREIGN KEY (drama_id) REFERENCES dramas(id) ON DELETE CASCADE, UNIQUE KEY uk_drama_episode (drama_id, episode_num))`);
      await connection.query(`CREATE TABLE IF NOT EXISTS drama_tags (drama_id INT, tag_id INT, PRIMARY KEY (drama_id, tag_id), FOREIGN KEY (drama_id) REFERENCES dramas(id) ON DELETE CASCADE, FOREIGN KEY (tag_id) REFERENCES tags(id) ON DELETE CASCADE)`);
      await connection.query(`CREATE TABLE IF NOT EXISTS users (id INT AUTO_INCREMENT PRIMARY KEY, username VARCHAR(50), phone VARCHAR(20), avatar VARCHAR(500), status TINYINT DEFAULT 1, promote_id VARCHAR(100), promote_name VARCHAR(100), coin_balance INT DEFAULT 0, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)`);
      try { await connection.query(`ALTER TABLE users ADD COLUMN promote_id VARCHAR(100)`); } catch {}
      try { await connection.query(`ALTER TABLE users ADD COLUMN promote_name VARCHAR(100)`); } catch {}
      try { await connection.query(`ALTER TABLE users ADD COLUMN coin_balance INT DEFAULT 0`); } catch {}
      try { await connection.query(`ALTER TABLE users ADD COLUMN token VARCHAR(255)`); } catch {}
      await connection.query(`CREATE TABLE IF NOT EXISTS settings (id INT AUTO_INCREMENT PRIMARY KEY, key_name VARCHAR(50) UNIQUE NOT NULL, value TEXT, updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP)`);

      const bcrypt = require('bcryptjs');
      const [admins] = await connection.query('SELECT id FROM admins LIMIT 1');
      if (!admins.length) {
        const hashedPassword = await bcrypt.hash('admin123', 10);
        await connection.query('INSERT INTO admins (username, password, nickname, role) VALUES (?, ?, ?, ?)', ['admin', hashedPassword, '超级管理员', 'super_admin']);
        console.log('✅ 默认管理员已创建: admin / admin123');
      }
      const [cats] = await connection.query('SELECT id FROM categories LIMIT 1');
      if (!cats.length) {
        await connection.query('INSERT INTO categories (name, sort) VALUES (?, ?), (?, ?)', ['短剧', 1, '电影', 2]);
        console.log('✅ 默认分类已创建');
      }
      console.log('✅ 数据库初始化完成 (MySQL 模式)');
    } finally {
      connection.release();
    }
  };

  getEpisodesList = async (filter = {}) => {
    const conn = await pool.getConnection();
    try {
      let where = '1=1';
      const params = [];
      if (filter.dramaId) { where += ' AND e.drama_id = ?'; params.push(filter.dramaId); }
      if (filter.episodeNum) { where += ' AND e.episode_num = ?'; params.push(filter.episodeNum); }
      if (filter.externalId) { where += ' AND e.video_id LIKE ?'; params.push(`%${filter.externalId}%`); }
      const [[{ total }]] = await conn.query(
        `SELECT COUNT(*) as total FROM drama_episodes e LEFT JOIN dramas d ON e.drama_id = d.id WHERE ${where}`,
        params
      );
      const page = parseInt(filter.page, 10) || 1;
      const pageSize = parseInt(filter.pageSize, 10) || 10;
      const offset = (page - 1) * pageSize;
      const [rows] = await conn.query(
        `SELECT e.id, e.drama_id, d.title, e.episode_num, e.video_id as external_id, COALESCE(e.created_at, d.created_at) as created_at
         FROM drama_episodes e LEFT JOIN dramas d ON e.drama_id = d.id WHERE ${where}
         ORDER BY e.drama_id, e.episode_num LIMIT ? OFFSET ?`,
        [...params, pageSize, offset]
      );
      return { list: rows.map(r => ({ ...r, external_id: r.external_id || '' })), total };
    } finally {
      conn.release();
    }
  };
}

module.exports = { pool, initDatabase, getEpisodesList };
