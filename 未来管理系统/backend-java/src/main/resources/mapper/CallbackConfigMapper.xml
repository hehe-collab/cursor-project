<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drama.mapper.CallbackConfigMapper">

  <resultMap id="ConfigMap" type="com.drama.entity.CallbackConfig">
    <id column="id" property="id"/>
    <result column="link_id" property="linkId"/>
    <result column="platform" property="platform"/>
    <result column="cold_start_count" property="coldStartCount"/>
    <result column="min_price_limit" property="minPriceLimit"/>
    <result column="replenish_callback_enabled" property="replenishCallbackEnabled"/>
    <result column="config_json" property="configJson"/>
    <result column="creator" property="creator"/>
    <result column="created_at" property="createdAt"/>
    <result column="updated_at" property="updatedAt"/>
  </resultMap>

  <select id="selectFiltered" resultMap="ConfigMap">
    SELECT * FROM callback_configs
    <where>
      <if test="platform != null and platform != ''">
        AND platform = #{platform}
      </if>
      <if test="linkIdContains != null and linkIdContains != ''">
        AND link_id LIKE CONCAT('%', #{linkIdContains}, '%')
      </if>
    </where>
    ORDER BY created_at DESC
  </select>

  <select id="selectById" resultMap="ConfigMap">
    SELECT * FROM callback_configs WHERE id = #{id}
  </select>

  <select id="selectForPromotionLinkCloneByKeys" resultMap="ConfigMap">
    SELECT * FROM callback_configs
    <where>
      <if test="keys != null and keys.size() &gt; 0">
        <foreach collection="keys" item="k" separator=" OR ">
          TRIM(link_id) = TRIM(#{k})
        </foreach>
      </if>
    </where>
  </select>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO callback_configs (
      link_id, platform, cold_start_count, min_price_limit,
      replenish_callback_enabled, config_json,
      creator, created_at, updated_at
    ) VALUES (
      #{linkId}, #{platform}, #{coldStartCount}, #{minPriceLimit},
      #{replenishCallbackEnabled}, #{configJson},
      #{creator}, NOW(), NOW()
    )
  </insert>

  <update id="update">
    UPDATE callback_configs SET
      link_id = #{linkId},
      platform = #{platform},
      cold_start_count = #{coldStartCount},
      min_price_limit = #{minPriceLimit},
      replenish_callback_enabled = #{replenishCallbackEnabled},
      config_json = #{configJson},
      updated_at = NOW()
    WHERE id = #{id}
  </update>

  <delete id="deleteById">
    DELETE FROM callback_configs WHERE id = #{id}
  </delete>

  <delete id="deleteByIds">
    DELETE FROM callback_configs WHERE id IN
    <foreach collection="ids" item="id" open="(" separator="," close=")">
      #{id}
    </foreach>
  </delete>
</mapper>
