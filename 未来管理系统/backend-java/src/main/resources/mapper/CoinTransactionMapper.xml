<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drama.mapper.CoinTransactionMapper">
  <select id="selectById" resultType="com.drama.entity.CoinTransaction">
    SELECT * FROM coin_transactions WHERE id = #{id}
  </select>
  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO coin_transactions (user_pk, delta, reason, ref_type, ref_id)
    VALUES (#{userPk}, #{delta}, #{reason}, #{refType}, #{refId})
  </insert>
</mapper>
