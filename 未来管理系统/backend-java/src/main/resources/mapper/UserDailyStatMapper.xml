<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drama.mapper.UserDailyStatMapper">
  <select id="selectById" resultType="com.drama.entity.UserDailyStat">
    SELECT * FROM user_daily_stats WHERE id = #{id}
  </select>
  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO user_daily_stats (user_pk, stat_date, metric, metric_value)
    VALUES (#{userPk}, #{statDate}, #{metric}, #{metricValue})
  </insert>
</mapper>
