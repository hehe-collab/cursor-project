<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drama.mapper.DramaDailyStatMapper">
  <select id="selectById" resultType="com.drama.entity.DramaDailyStat">
    SELECT * FROM drama_daily_stats WHERE id = #{id}
  </select>
  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO drama_daily_stats (drama_id, stat_date, metric, metric_value)
    VALUES (#{dramaId}, #{statDate}, #{metric}, #{metricValue})
  </insert>
</mapper>
