<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drama.mapper.AdminMapper">

  <resultMap id="BaseMap" type="com.drama.entity.Admin">
    <id column="id" property="id"/>
    <result column="username" property="username"/>
    <result column="password" property="password"/>
    <result column="nickname" property="nickname"/>
    <result column="role" property="role"/>
    <result column="created_at" property="createdAt"/>
    <result column="updated_at" property="updatedAt"/>
  </resultMap>

  <select id="selectByUsername" resultMap="BaseMap">
    SELECT * FROM admins WHERE username = #{username} LIMIT 1
  </select>

  <select id="selectById" resultMap="BaseMap">
    SELECT * FROM admins WHERE id = #{id} LIMIT 1
  </select>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO admins (username, password, nickname, role)
    VALUES (#{username}, #{password}, #{nickname}, #{role})
  </insert>
</mapper>
