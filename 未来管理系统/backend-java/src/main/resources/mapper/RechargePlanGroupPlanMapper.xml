<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drama.mapper.RechargePlanGroupPlanMapper">

  <resultMap id="RelMap" type="com.drama.entity.RechargePlanGroupPlan">
    <id column="id" property="id"/>
    <result column="group_id" property="groupId"/>
    <result column="plan_id" property="planId"/>
    <result column="sort_order" property="sortOrder"/>
  </resultMap>

  <delete id="deleteByGroupId">
    DELETE FROM recharge_plan_group_plans WHERE group_id = #{groupId}
  </delete>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO recharge_plan_group_plans (group_id, plan_id, sort_order)
    VALUES (#{groupId}, #{planId}, #{sortOrder})
  </insert>

  <select id="selectByGroupIdOrdered" resultMap="RelMap">
    SELECT * FROM recharge_plan_group_plans
    WHERE group_id = #{groupId}
    ORDER BY sort_order ASC, id ASC
  </select>
</mapper>
