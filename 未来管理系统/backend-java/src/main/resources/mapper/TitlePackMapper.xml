<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drama.mapper.TitlePackMapper">

  <resultMap id="RowMap" type="com.drama.entity.TitlePack">
    <id column="id" property="id"/>
    <result column="name" property="name"/>
    <result column="content" property="content"/>
    <result column="created_by" property="createdBy"/>
    <result column="created_by_name" property="createdByName"/>
    <result column="created_at" property="createdAt"/>
    <result column="updated_at" property="updatedAt"/>
  </resultMap>

  <select id="selectAllOrderByIdDesc" resultMap="RowMap">
    SELECT * FROM title_packs ORDER BY id DESC
  </select>

  <select id="selectById" resultMap="RowMap">
    SELECT * FROM title_packs WHERE id = #{id}
  </select>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO title_packs (name, content, created_by, created_by_name, created_at, updated_at)
    VALUES (#{name}, #{content}, #{createdBy}, #{createdByName}, NOW(), NOW())
  </insert>

  <update id="update">
    UPDATE title_packs SET
      name = #{name},
      content = #{content},
      updated_at = NOW()
    WHERE id = #{id}
  </update>

  <delete id="deleteById">
    DELETE FROM title_packs WHERE id = #{id}
  </delete>

  <delete id="deleteByIds">
    DELETE FROM title_packs WHERE id IN
    <foreach collection="ids" item="id" open="(" separator="," close=")">
      #{id}
    </foreach>
  </delete>
</mapper>
