# 复制为 .env.dev 或导出后启动；Spring Boot 默认不读取本文件，请配合 scripts/start-dev.sh 或手动 export

DB_HOST=localhost
DB_PORT=3306
DB_NAME=drama_system
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# ========== 加密密钥（生产环境必须修改！）==========
ENCRYPT_SECRET_KEY=change-me-in-production-use-openssl-rand-base64-32

ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_VOD_REGION=cn-shanghai

APP_UPLOAD_DIR=./uploads
UPLOAD_PATH=./uploads

SERVER_PORT=3001
SPRING_PROFILES_ACTIVE=dev
LOG_PATH=./logs
MYSQL_PASSWORD=

# TikTok API / OAuth（与 application.yml tiktok.*、drama.tiktok 一致者可只配 TIKTOK_APP_ID 等）
TIKTOK_APP_ID=your_app_id_here
TIKTOK_APP_SECRET=your_app_secret_here
TIKTOK_PUBLIC_BASE_URL=https://business-api.tiktok.com
TIKTOK_OPEN_API_VERSION=v1.3
TIKTOK_API_CLIENT_TIMEOUT_MS=30000
TIKTOK_API_CLIENT_ENABLED=true
TIKTOK_API_CLIENT_DEBUG=false
TIKTOK_TOKEN_REFRESH_ADVANCE_MINUTES=5
TIKTOK_API_MAX_RETRIES=3
TIKTOK_API_RETRY_INTERVAL_MS=1000
TIKTOK_OAUTH_AUTH_URL=https://business-api.tiktok.com/portal/auth
TIKTOK_OAUTH_TOKEN_URL=https://business-api.tiktok.com/open_api/v1.3/oauth2/access_token/
TIKTOK_OAUTH_REFRESH_TOKEN_URL=https://business-api.tiktok.com/open_api/v1.3/oauth2/refresh_token/
TIKTOK_OAUTH_REDIRECT_URI=http://localhost:3001/api/tiktok/oauth/callback
TIKTOK_REDIRECT_URI=http://localhost:3001/api/tiktok/oauth/callback
TIKTOK_OAUTH_SCOPE=user.info.basic,ad.management,reporting
