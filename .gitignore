.cursor/
*.cursor.tmp

# ---- 通用编辑器 / IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- 日志 ----
*.log
logs/

# ---- 临时 / 备份文件 ----
*.tmp
*.temp
*.bak
*~
